....................       unsigned int16 NUM_OF_PCKT   = NEWTRX_TO_CPIC_ARRAY[11];
03122:  MOVFF  123,4E8
03126:  MOVFF  124,4E7
0312A:  MOVFF  125,4E6
0312E:  MOVFF  126,4E5
03132:  MOVLB  4
03134:  CLRF   xEA
03136:  MOVFF  12A,4E9
....................       
....................       NEW_TRX_SEND_DATA_PACKETS_TO_GS(START_ADDRESS, NUM_OF_PCKT); 
0313A:  MOVFF  4E8,4F2
0313E:  MOVFF  4E7,4F1
03142:  MOVFF  4E6,4F0
03146:  MOVFF  4E5,4EF
0314A:  CLRF   xF6
0314C:  CLRF   xF5
0314E:  MOVFF  4EA,4F4
03152:  MOVFF  4E9,4F3
03156:  MOVLB  0
03158:  RCALL  2ECA
0315A:  MOVLB  1
....................    }
0315C:  MOVLB  0
0315E:  GOTO   5B34 (RETURN)
.................... }
