.................... {
....................    if( NEWTRX_TO_CPIC_ARRAY[2] == 0x00 && NEWTRX_TO_CPIC_ARRAY[3] == 0x10 )                 
*
03104:  MOVLB  1
03106:  MOVF   x21,F
03108:  BNZ   315C
0310A:  MOVF   x22,W
0310C:  SUBLW  10
0310E:  BNZ   315C
