0454C:  MOVLW  01
0454E:  MOVLB  4
04550:  ADDWF  xF7,F
04552:  BTFSC  FD8.0
04554:  INCF   xF8,F
04556:  BTFSC  FD8.2
04558:  INCF   xF9,F
0455A:  BTFSC  FD8.2
0455C:  INCF   xFA,F
0455E:  BRA    438E
....................    }
....................    
....................    Delay_ms(1000);
04560:  MOVLW  04
04562:  MOVLB  5
04564:  MOVWF  x02
04566:  MOVLW  FA
04568:  MOVWF  x04
0456A:  MOVLB  0
0456C:  CALL   10AE
04570:  MOVLB  5
04572:  DECFSZ x02,F
04574:  BRA    4566
....................    OLD_TRX_RX_MODE(); // turning on trnaceiver receive mode
04576:  MOVLB  0
04578:  CALL   1144
0457C:  RETURN 0
....................    
.................... } 
