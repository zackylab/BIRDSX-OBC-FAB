.................... // Download data from FM with full access to Flash memory
.................... Void PACKETS_DOWNLOAD_WITH_FM_FULL_ACCESS()
.................... {
....................    if( NEWTRX_TO_CPIC_ARRAY[2] == 0x00 && NEWTRX_TO_CPIC_ARRAY[3] == 0x11 )                 
*
032F4:  MOVLB  1
032F6:  MOVF   x21,F
032F8:  BTFSS  FD8.2
032FA:  BRA    33F8
032FC:  MOVF   x22,W
032FE:  SUBLW  11
03300:  BTFSS  FD8.2
03302:  BRA    33F8
....................    {
....................       Fprintf(PC,"NEW_TRX_PACKETS_DOWNLOAD_WITH_FM_ACCESS\n\r");
03304:  MOVLW  68
03306:  MOVWF  FF6
03308:  MOVLW  06
0330A:  MOVWF  FF7
0330C:  MOVLW  00
0330E:  MOVWF  FF8
03310:  MOVLB  0
03312:  CALL   111C
....................       
....................       unsigned int32 START_ADDRESS = make32( NEWTRX_TO_CPIC_ARRAY[4] , NEWTRX_TO_CPIC_ARRAY[5], NEWTRX_TO_CPIC_ARRAY[6], NEWTRX_TO_CPIC_ARRAY[7] );
....................       unsigned int16 NUM_OF_PCKT   = NEWTRX_TO_CPIC_ARRAY[11];
....................       unsigned int8 acces_time = 0;
03316:  MOVFF  123,4E8
0331A:  MOVFF  124,4E7
0331E:  MOVFF  125,4E6
03322:  MOVFF  126,4E5
03326:  MOVLB  4
03328:  CLRF   xEA
0332A:  MOVFF  12A,4E9
0332E:  CLRF   xEB
....................       
....................       // calculating acces time
....................       if( ( 0<NUM_OF_PCKT ) && (NUM_OF_PCKT<=100) ) acces_time = 50  ;    // adjust this values after checking
03330:  MOVF   xEA,F
03332:  BNZ   333A
03334:  MOVF   xE9,W
03336:  SUBLW  00
03338:  BC    3348
0333A:  MOVF   xEA,F
0333C:  BNZ   3348
0333E:  MOVF   xE9,W
03340:  SUBLW  64
03342:  BNC   3348
03344:  MOVLW  32
03346:  MOVWF  xEB
....................       if( (100<NUM_OF_PCKT) && (NUM_OF_PCKT<=200) ) acces_time = 100 ;
03348:  MOVF   xEA,F
0334A:  BNZ   3352
0334C:  MOVF   xE9,W
0334E:  SUBLW  64
03350:  BC    3360
03352:  MOVF   xEA,F
03354:  BNZ   3360
03356:  MOVF   xE9,W
03358:  SUBLW  C8
0335A:  BNC   3360
0335C:  MOVLW  64
0335E:  MOVWF  xEB
....................       if( (200<NUM_OF_PCKT) && (NUM_OF_PCKT<=255) ) acces_time = 150 ;
03360:  MOVF   xEA,F
03362:  BNZ   336A
03364:  MOVF   xE9,W
03366:  SUBLW  C8
03368:  BC    3374
0336A:  MOVF   xEA,W
0336C:  SUBLW  00
0336E:  BNC   3374
03370:  MOVLW  96
03372:  MOVWF  xEB
....................       
....................       GET_FM_ACCESS_FROM_MAIN_PIC(acces_time);
03374:  MOVFF  4EB,4EC
03378:  MOVLB  0
0337A:  RCALL  3162
....................       
....................       if( MPIC_TO_CPIC_ARRAY[0] == 0xB0 && MPIC_TO_CPIC_ARRAY[1] == 0xFA && MPIC_TO_CPIC_ARRAY[31] == 0xB1 )
0337C:  MOVLB  2
0337E:  MOVF   xAF,W
03380:  SUBLW  B0
03382:  BNZ   33C8
03384:  MOVF   xB0,W
03386:  SUBLW  FA
03388:  BNZ   33C8
0338A:  MOVF   xCE,W
0338C:  SUBLW  B1
0338E:  BNZ   33C8
....................       {
....................          Fprintf(PC,"FM access request succeful\n\r");
03390:  MOVLW  92
03392:  MOVWF  FF6
03394:  MOVLW  06
03396:  MOVWF  FF7
03398:  MOVLW  00
0339A:  MOVWF  FF8
0339C:  MOVLB  0
0339E:  CALL   111C
....................          NEW_TRX_SEND_DATA_PACKETS_TO_GS(START_ADDRESS, NUM_OF_PCKT);    // send packets
033A2:  MOVFF  4E8,4F2
033A6:  MOVFF  4E7,4F1
033AA:  MOVFF  4E6,4F0
033AE:  MOVFF  4E5,4EF
033B2:  MOVLB  4
033B4:  CLRF   xF6
033B6:  CLRF   xF5
033B8:  MOVFF  4EA,4F4
033BC:  MOVFF  4E9,4F3
033C0:  MOVLB  0
033C2:  RCALL  2ECA
....................       }
033C4:  BRA    33E2
033C6:  MOVLB  2
....................       
....................       else
....................       {
....................          Fprintf(PC,"FM access request not-succeful\n\r");
033C8:  MOVLW  B0
033CA:  MOVWF  FF6
033CC:  MOVLW  06
033CE:  MOVWF  FF7
033D0:  MOVLW  00
033D2:  MOVWF  FF8
033D4:  MOVLB  0
033D6:  CALL   111C
....................          NEWTRX_SEND_ACKNOWLEDGEMENT(0);
033DA:  MOVLB  4
033DC:  CLRF   xEF
033DE:  MOVLB  0
033E0:  RCALL  31AA
....................       }
....................       
....................       CLEAR_DATA_ARRAY(MPIC_TO_CPIC_ARRAY, 50);
033E2:  MOVLW  02
033E4:  MOVLB  4
033E6:  MOVWF  xF0
033E8:  MOVLW  AF
033EA:  MOVWF  xEF
033EC:  MOVLW  32
033EE:  MOVWF  xF1
033F0:  MOVLB  0
033F2:  CALL   1594
033F6:  MOVLB  1
....................    }
033F8:  MOVLB  0
033FA:  GOTO   5B38 (RETURN)
.................... }
