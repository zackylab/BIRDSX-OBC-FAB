.................... 
.................... // this function will be used to send one packet intead of CW morse code
.................... Void OLD_TRX_SEND_1PCKT_BEACON()
.................... {
....................    CW_INTERVAL = 120;
*
0278E:  CLRF   1F
02790:  MOVLW  78
02792:  MOVWF  1E
....................    // not changin values assigning____________________________
....................  
....................    //----Ground stationCall sign---------------[ 0-----5 ]
....................    CPIC_TO_OLDTRX_ARRAY[0] = GS_callsign_leter_1 ;     
02794:  MOVFF  31D,241
....................    CPIC_TO_OLDTRX_ARRAY[1] = GS_callsign_leter_2 ;                    
02798:  MOVFF  31E,242
....................    CPIC_TO_OLDTRX_ARRAY[2] = GS_callsign_leter_3 ;     
0279C:  MOVFF  31F,243
....................    CPIC_TO_OLDTRX_ARRAY[3] = GS_callsign_leter_4 ;     
027A0:  MOVFF  320,244
....................    CPIC_TO_OLDTRX_ARRAY[4] = GS_callsign_leter_5 ;     
027A4:  MOVFF  321,245
....................    CPIC_TO_OLDTRX_ARRAY[5] = GS_callsign_leter_6 ;     
027A8:  MOVFF  322,246
....................       
....................    //----Dest SSID-----------------------------[ 6 ]
....................    CPIC_TO_OLDTRX_ARRAY[6] = 0x30 ;     //char 0
027AC:  MOVLW  30
027AE:  MOVLB  2
027B0:  MOVWF  x47
.................... 
....................    //----Satellite Call Sign-------------------[ 7 - 12 ]
....................    CPIC_TO_OLDTRX_ARRAY[7]  = ST_callsign_leter_1 ;     
027B2:  MOVFF  323,248
....................    CPIC_TO_OLDTRX_ARRAY[8]  = ST_callsign_leter_2 ;                    
027B6:  MOVFF  324,249
....................    CPIC_TO_OLDTRX_ARRAY[9]  = ST_callsign_leter_3 ;     
027BA:  MOVFF  325,24A
....................    CPIC_TO_OLDTRX_ARRAY[10] = ST_callsign_leter_4 ;     
027BE:  MOVFF  326,24B
....................    CPIC_TO_OLDTRX_ARRAY[11] = ST_callsign_leter_5 ;     
027C2:  MOVFF  327,24C
....................    CPIC_TO_OLDTRX_ARRAY[12] = ST_callsign_leter_6 ; 
027C6:  MOVFF  328,24D
....................    
....................    //----Dest SSID-----------------------------[ 13 ]
....................    CPIC_TO_OLDTRX_ARRAY[13] = 0x30 ;    //char 0
027CA:  MOVWF  x4E
....................    
....................    //----Control-------------------------------[ 14 ]
....................    CPIC_TO_OLDTRX_ARRAY[14] = 0x3E ;    
027CC:  MOVLW  3E
027CE:  MOVWF  x4F
....................    
....................    //----PID-----------------------------------[ 15 ]
....................    CPIC_TO_OLDTRX_ARRAY[15] = 0xF0 ;    
027D0:  MOVLW  F0
027D2:  MOVWF  x50
.................... 
....................    //----Packet specified data-----------------[ 16 - 21 ]
....................    CPIC_TO_OLDTRX_ARRAY[16] = 0xFF ;
027D4:  SETF   x51
....................    CPIC_TO_OLDTRX_ARRAY[17] = 0xF0 ;
027D6:  MOVWF  x52
....................    CPIC_TO_OLDTRX_ARRAY[18] = 0xFf ;
027D8:  SETF   x53
....................    //________________________________________________________________
....................    
....................    OLD_TRX_TX_MODE(); // turning on trnaceiver transmit mode
027DA:  MOVLB  0
027DC:  RCALL  2754
....................    Delay_ms(500);
027DE:  MOVLW  02
027E0:  MOVLB  4
027E2:  MOVWF  xF1
027E4:  MOVLW  FA
027E6:  MOVLB  5
027E8:  MOVWF  x04
027EA:  MOVLB  0
027EC:  CALL   10AE
027F0:  MOVLB  4
027F2:  DECFSZ xF1,F
027F4:  BRA    27E4
....................    
....................    CPIC_TO_OLDTRX_ARRAY[19] = 0x00 ;
027F6:  MOVLB  2
027F8:  CLRF   x54
....................    CPIC_TO_OLDTRX_ARRAY[20] = 0x00 ;
027FA:  CLRF   x55
....................    CPIC_TO_OLDTRX_ARRAY[21] = 0x01 ;
027FC:  MOVLW  01
027FE:  MOVWF  x56
....................    
....................    //----Pay Load------------------------------[ 22 - 102 ] (81 bytes)______
....................    // we put CW HSK data here from 22 element to 37 th element 
....................    for (int i = 22; i < 38 ; i++)
02800:  MOVLW  16
02802:  MOVLB  4
02804:  MOVWF  xE9
02806:  MOVF   xE9,W
02808:  SUBLW  25
0280A:  BNC   2840
....................    {      
....................       CPIC_TO_OLDTRX_ARRAY[i] = CW_DATA[i-22];
0280C:  CLRF   03
0280E:  MOVF   xE9,W
02810:  ADDLW  41
02812:  MOVWF  01
02814:  MOVLW  02
02816:  ADDWFC 03,F
02818:  MOVFF  03,4F2
0281C:  MOVLW  16
0281E:  SUBWF  xE9,W
02820:  CLRF   03
02822:  ADDLW  22
02824:  MOVWF  FE9
02826:  MOVLW  00
02828:  ADDWFC 03,W
0282A:  MOVWF  FEA
0282C:  MOVFF  FEF,4F3
02830:  MOVFF  4F2,FEA
02834:  MOVFF  01,FE9
02838:  MOVFF  4F3,FEF
0283C:  INCF   xE9,F
0283E:  BRA    2806
....................    }
....................    
....................    // just a separator
....................    CPIC_TO_OLDTRX_ARRAY[38] = 0xAA ;
02840:  MOVLW  AA
02842:  MOVLB  2
02844:  MOVWF  x67
....................    CPIC_TO_OLDTRX_ARRAY[39] = 0xBB ;
02846:  MOVLW  BB
02848:  MOVWF  x68
....................    CPIC_TO_OLDTRX_ARRAY[40] = 0xCC ;
0284A:  MOVLW  CC
0284C:  MOVWF  x69
....................    
....................    //Adding time
....................    
....................    CPIC_TO_OLDTRX_ARRAY[41] = RPIC_TO_CPIC_ARRAY[2] ;
0284E:  MOVFF  77,26A
....................    CPIC_TO_OLDTRX_ARRAY[42] = RPIC_TO_CPIC_ARRAY[3];
02852:  MOVFF  78,26B
....................    CPIC_TO_OLDTRX_ARRAY[43] = RPIC_TO_CPIC_ARRAY[4]  ;
02856:  MOVFF  79,26C
....................    CPIC_TO_OLDTRX_ARRAY[44] = RPIC_TO_CPIC_ARRAY[5] ;
0285A:  MOVFF  7A,26D
....................    CPIC_TO_OLDTRX_ARRAY[45] = RPIC_TO_CPIC_ARRAY[6]  ;
0285E:  MOVFF  7B,26E
....................    CPIC_TO_OLDTRX_ARRAY[46] = RPIC_TO_CPIC_ARRAY[7]  ;
02862:  MOVFF  7C,26F
....................    
....................    // read FM data
....................    for (unsigned int32 i = 47; i <= 102; i++)
02866:  MOVLB  4
02868:  CLRF   xED
0286A:  CLRF   xEC
0286C:  CLRF   xEB
0286E:  MOVLW  2F
02870:  MOVWF  xEA
02872:  MOVF   xED,F
02874:  BNZ   28FE
02876:  MOVF   xEC,F
02878:  BNZ   28FE
0287A:  MOVF   xEB,F
0287C:  BNZ   28FE
0287E:  MOVF   xEA,W
02880:  SUBLW  66
02882:  BNC   28FE
....................    {      
....................       CPIC_TO_OLDTRX_ARRAY[i] = FM_BYTE_READ_( TLE_ADDRESS + i-47 );
02884:  MOVLW  41
02886:  ADDWF  xEA,W
02888:  MOVWF  01
0288A:  MOVLW  02
0288C:  ADDWFC xEB,W
0288E:  MOVWF  03
02890:  MOVFF  01,4F1
02894:  MOVWF  xF2
02896:  MOVF   xEA,W
02898:  MOVLB  0
0289A:  ADDWF  x6E,W
0289C:  MOVLB  4
0289E:  MOVWF  xF3
028A0:  MOVF   xEB,W
028A2:  MOVLB  0
028A4:  ADDWFC x6F,W
028A6:  MOVLB  4
028A8:  MOVWF  xF4
028AA:  MOVF   xEC,W
028AC:  MOVLB  0
028AE:  ADDWFC x70,W
028B0:  MOVLB  4
028B2:  MOVWF  xF5
028B4:  MOVF   xED,W
028B6:  MOVLB  0
028B8:  ADDWFC x71,W
028BA:  MOVLB  4
028BC:  MOVWF  xF6
028BE:  MOVLW  2F
028C0:  SUBWF  xF3,F
028C2:  MOVLW  00
028C4:  SUBWFB xF4,F
028C6:  SUBWFB xF5,F
028C8:  SUBWFB xF6,F
028CA:  MOVFF  4F6,50D
028CE:  MOVFF  4F5,50C
028D2:  MOVFF  4F4,50B
028D6:  MOVFF  4F3,50A
028DA:  MOVLB  0
028DC:  RCALL  236E
028DE:  MOVFF  4F2,FEA
028E2:  MOVFF  4F1,FE9
028E6:  MOVFF  01,FEF
028EA:  MOVLW  01
028EC:  MOVLB  4
028EE:  ADDWF  xEA,F
028F0:  BTFSC  FD8.0
028F2:  INCF   xEB,F
028F4:  BTFSC  FD8.2
028F6:  INCF   xEC,F
028F8:  BTFSC  FD8.2
028FA:  INCF   xED,F
028FC:  BRA    2872
....................    }
....................    
....................    //----CRC values----------------------------[ 103, 104 ] 
....................    unsigned int16 CRC_VALUE = CALCULATE_CRC(CPIC_TO_OLDTRX_ARRAY, 103);  
028FE:  MOVLW  02
02900:  MOVLB  5
02902:  MOVWF  x03
02904:  MOVLW  41
02906:  MOVWF  x02
02908:  MOVLW  67
0290A:  MOVWF  x04
0290C:  MOVLB  0
0290E:  RCALL  2454
02910:  MOVFF  02,4EF
02914:  MOVFF  01,4EE
....................    CPIC_TO_OLDTRX_ARRAY[103] = (unsigned int8) (  CRC_VALUE       & 0x00FF );  // LOW byte
02918:  MOVFF  4EE,2A8
0291C:  MOVLB  2
....................    CPIC_TO_OLDTRX_ARRAY[104] = (unsigned int8) ( (CRC_VALUE >> 8) & 0x00FF );  // HIGH byte
0291E:  MOVFF  4EF,2A9
02922:  MOVLB  2
....................    
....................    // transfering data array to old tranceiver________________
....................    for(int i = 0; i<105; i++)
02924:  MOVLB  4
02926:  CLRF   xF0
02928:  MOVF   xF0,W
0292A:  SUBLW  68
0292C:  BNC   294C
....................    {
....................       fputc(CPIC_TO_OLDTRX_ARRAY[i],OLD_TRX);
0292E:  CLRF   03
02930:  MOVF   xF0,W
02932:  ADDLW  41
02934:  MOVWF  FE9
02936:  MOVLW  02
02938:  ADDWFC 03,W
0293A:  MOVWF  FEA
0293C:  MOVFF  FEF,4F1
02940:  MOVF   xF1,W
02942:  MOVLB  0
02944:  RCALL  2786
02946:  MOVLB  4
02948:  INCF   xF0,F
0294A:  BRA    2928
....................    } 
....................    
....................    // Delay untill packet transmission   
....................    Delay_ms(300);
0294C:  MOVLW  02
0294E:  MOVWF  xF1
02950:  MOVLW  96
02952:  MOVLB  5
02954:  MOVWF  x04
02956:  MOVLB  0
02958:  CALL   10AE
0295C:  MOVLB  4
0295E:  DECFSZ xF1,F
02960:  BRA    2950
....................    OLD_TRX_RX_MODE(); // turning on trnaceiver receive mode 
02962:  MOVLB  0
02964:  CALL   1144
02968:  GOTO   2B0E (RETURN)
.................... } 
