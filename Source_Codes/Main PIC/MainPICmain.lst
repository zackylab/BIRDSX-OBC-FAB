0498E:  ADDLW  10
04990:  MOVWF  FE9
04992:  MOVLW  01
04994:  ADDWFC 03,W
04996:  MOVWF  FEA
04998:  MOVFF  FEF,43E
0499C:  MOVLW  37
0499E:  MOVWF  x3F
049A0:  MOVLB  0
049A2:  CALL   20DA
049A6:  MOVLW  20
049A8:  BTFSS  F9E.4
049AA:  BRA    49A8
049AC:  MOVWF  FAD
049AE:  MOVLB  4
049B0:  INCF   x3C,F
049B2:  BRA    4984
....................    }
....................    printline();
049B4:  MOVLB  0
049B6:  CALL   2096
....................    printline();
049BA:  CALL   2096
049BE:  GOTO   4A5E (RETURN)
.................... }
