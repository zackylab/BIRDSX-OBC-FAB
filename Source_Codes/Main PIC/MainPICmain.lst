04A12:  CLRF   x3A
04A14:  MOVF   x3A,W
04A16:  SUBLW  02
04A18:  BNC   4A38
....................       {
....................         fputc(MPIC_TO_FAB_ARRAY[i], FAB);
04A1A:  CLRF   03
04A1C:  MOVF   x3A,W
04A1E:  ADDLW  F0
04A20:  MOVWF  FE9
04A22:  MOVLW  00
04A24:  ADDWFC 03,W
04A26:  MOVWF  FEA
04A28:  MOVFF  FEF,43C
04A2C:  MOVF   x3C,W
04A2E:  MOVLB  0
04A30:  BRA    48F0
04A32:  MOVLB  4
04A34:  INCF   x3A,F
04A36:  BRA    4A14
....................       }
....................       Delay_ms(wait_time);
