088AA:  CLRF   xFD
088AC:  MOVF   xFD,W
088AE:  SUBLW  04
088B0:  BNC   88CC
....................       {
....................          if( CPic_Read() == 0xB0 )
088B2:  MOVLB  0
088B4:  RCALL  8846
088B6:  MOVF   01,W
088B8:  SUBLW  B0
088BA:  BNZ   88C6
....................          {
....................             CPIC_TO_MPIC_ARRAY[0] = 0xB0;
088BC:  MOVLW  B0
088BE:  MOVWF  xB9
....................             break;
088C0:  MOVLB  3
088C2:  BRA    88CC
088C4:  MOVLB  0
....................          }
088C6:  MOVLB  3
088C8:  INCF   xFD,F
088CA:  BRA    88AC
....................       }
....................       
....................       for(int gi = 1; gi<=50; gi++)
088CC:  MOVLW  01
088CE:  MOVWF  xFE
088D0:  MOVF   xFE,W
088D2:  SUBLW  32
088D4:  BNC   8900
....................       {
....................         CPIC_TO_MPIC_ARRAY[gi] = CPIC_Read();         
088D6:  CLRF   03
088D8:  MOVF   xFE,W
088DA:  ADDLW  B9
088DC:  MOVWF  01
088DE:  MOVLW  00
088E0:  ADDWFC 03,F
088E2:  MOVFF  01,3FF
088E6:  MOVFF  03,400
088EA:  MOVLB  0
088EC:  RCALL  8846
088EE:  MOVFF  400,FEA
088F2:  MOVFF  3FF,FE9
088F6:  MOVFF  01,FEF
088FA:  MOVLB  3
088FC:  INCF   xFE,F
088FE:  BRA    88D0
08900:  MOVLB  0
....................       }
....................    }
08902:  GOTO   B2BC (RETURN)
.................... }
