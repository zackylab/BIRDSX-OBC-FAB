.................... {
....................    Fprintf(PC,"Received comand from FAB pic >> ");
04970:  MOVLW  4C
04972:  MOVWF  FF6
04974:  MOVLW  11
04976:  MOVWF  FF7
04978:  MOVLW  00
0497A:  MOVWF  FF8
