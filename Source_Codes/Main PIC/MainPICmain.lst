04A3C:  INCF   x3C,F
04A3E:  DECF   x3C,F
04A40:  BTFSC  FD8.2
04A42:  BRA    4A50
04A44:  SETF   x3E
04A46:  MOVLB  0
04A48:  CALL   1DA0
04A4C:  MOVLB  4
04A4E:  BRA    4A3E
04A50:  MOVFF  434,43E
04A54:  MOVLB  0
04A56:  CALL   1DA0
....................       
....................       CHECK_UART_INCOMING_FROM_FAB_PIC() ;
04A5A:  BRA    48FE
....................       PRINT_RECIVED_COMMAND_FROM_FAB_PIC();
04A5C:  BRA    4970
....................       
....................       if( FAB_TO_MPIC_ARRAY[0] == 0xFA && FAB_TO_MPIC_ARRAY[inc_array_length-1] == 0xFB )
04A5E:  MOVLB  1
04A60:  MOVF   x10,W
04A62:  SUBLW  FA
04A64:  BNZ   4A9E
04A66:  MOVLW  01
04A68:  MOVLB  4
04A6A:  SUBWF  x38,W
04A6C:  CLRF   03
04A6E:  ADDLW  10
04A70:  MOVWF  FE9
04A72:  MOVLW  01
04A74:  ADDWFC 03,W
04A76:  MOVWF  FEA
04A78:  MOVF   FEF,W
04A7A:  SUBLW  FB
