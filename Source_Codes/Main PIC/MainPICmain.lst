.................... 
.................... //______________________4KB,32KB,64KB Sector Erase____________________________________________________\\
.................... void MAIN_FM_SECTOR_ERASE(unsigned int32 sector_address,char sector_size,  int16 delay = 1000)
.................... {
....................    
....................    adsress[0]  = (unsigned int8)((sector_address>>24) & 0xFF);   // 0x __ 00 00 00
*
02AD8:  MOVLB  4
02ADA:  MOVFF  413,2D4
02ADE:  CLRF   03
....................    adsress[1]  = (unsigned int8)((sector_address>>16) & 0xFF);   // 0x 00 __ 00 00
02AE0:  MOVFF  412,2D5
02AE4:  CLRF   03
....................    adsress[2]  = (unsigned int8)((sector_address>>8)  & 0xFF);   // 0x 00 00 __ 00
02AE6:  MOVFF  411,2D6
02AEA:  CLRF   03
....................    adsress[3]  = (unsigned int8)((sector_address)     & 0xFF);   // 0x 00 00 00 __
02AEC:  MOVFF  410,2D7
02AF0:  CLRF   03
....................    
....................    MAIN_FM_WRITE_ENABLE();
02AF2:  MOVLB  0
02AF4:  RCALL  2ABC
....................    Output_low(Pin_E2);             //lower the CS PIN
02AF6:  BCF    F96.2
02AF8:  BCF    F8D.2
.................... 
....................    ///////////////////////////////////////////////////////////////////
.................... 
....................    if( Sector_size == 4  ) spi_xfer(MAIN_FM,0x21);                    // 4KB Sector erase
02AFA:  MOVLB  4
02AFC:  MOVF   x14,W
02AFE:  SUBLW  04
02B00:  BNZ   2B14
02B02:  MOVLW  21
02B04:  MOVWF  x1F
02B06:  MOVLW  08
02B08:  MOVWF  x20
02B0A:  MOVLW  01
02B0C:  MOVWF  x21
02B0E:  MOVLB  0
02B10:  RCALL  2386
02B12:  MOVLB  4
....................    if( Sector_size == 32 ) spi_xfer(MAIN_FM,0x5C);                    // 32KB Sector erase
02B14:  MOVF   x14,W
02B16:  SUBLW  20
02B18:  BNZ   2B2C
02B1A:  MOVLW  5C
02B1C:  MOVWF  x1F
02B1E:  MOVLW  08
02B20:  MOVWF  x20
02B22:  MOVLW  01
02B24:  MOVWF  x21
02B26:  MOVLB  0
02B28:  RCALL  2386
02B2A:  MOVLB  4
....................    if( Sector_size == 64 ) spi_xfer(MAIN_FM,0xDC);                    // 64KB Sector erase
02B2C:  MOVF   x14,W
02B2E:  SUBLW  40
02B30:  BNZ   2B44
02B32:  MOVLW  DC
02B34:  MOVWF  x1F
02B36:  MOVLW  08
02B38:  MOVWF  x20
02B3A:  MOVLW  01
02B3C:  MOVWF  x21
02B3E:  MOVLB  0
02B40:  RCALL  2386
02B42:  MOVLB  4
....................    
....................    spi_xfer(MAIN_FM,adsress[0]);   
02B44:  MOVFF  2D4,41F
02B48:  MOVLW  08
02B4A:  MOVWF  x20
02B4C:  MOVLW  01
02B4E:  MOVWF  x21
02B50:  MOVLB  0
02B52:  RCALL  2386
....................    spi_xfer(MAIN_FM,adsress[1]);    
02B54:  MOVFF  2D5,41F
02B58:  MOVLW  08
02B5A:  MOVLB  4
02B5C:  MOVWF  x20
02B5E:  MOVLW  01
02B60:  MOVWF  x21
02B62:  MOVLB  0
02B64:  RCALL  2386
....................    spi_xfer(MAIN_FM,adsress[2]);    
02B66:  MOVFF  2D6,41F
02B6A:  MOVLW  08
02B6C:  MOVLB  4
02B6E:  MOVWF  x20
02B70:  MOVLW  01
02B72:  MOVWF  x21
02B74:  MOVLB  0
02B76:  RCALL  2386
....................    spi_xfer(MAIN_FM,adsress[3]);
02B78:  MOVFF  2D7,41F
02B7C:  MOVLW  08
02B7E:  MOVLB  4
02B80:  MOVWF  x20
02B82:  MOVLW  01
02B84:  MOVWF  x21
02B86:  MOVLB  0
02B88:  CALL   2386
....................    //////////////////////////////////////////////////////////////////
....................    Output_high(Pin_E2);           //take CS PIN higher back
02B8C:  BCF    F96.2
02B8E:  BSF    F8D.2
.................... 
....................    delay_ms(delay); 
02B90:  MOVFF  416,417
02B94:  MOVLB  4
02B96:  INCF   x17,F
02B98:  DECF   x17,F
02B9A:  BTFSC  FD8.2
02B9C:  BRA    2BAA
02B9E:  SETF   x3E
02BA0:  MOVLB  0
02BA2:  CALL   1DA0
02BA6:  MOVLB  4
02BA8:  BRA    2B98
02BAA:  MOVFF  415,43E
02BAE:  MOVLB  0
02BB0:  CALL   1DA0
....................    return;
02BB4:  RETURN 0
.................... }
