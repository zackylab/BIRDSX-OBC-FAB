.................... void READ_MP_RTC_()
.................... {
....................    rtc_time_t  read_clock; 
....................    rtc_read(&read_clock);
*
03388:  MOVLB  F
0338A:  BSF    x5F.0
0338C:  BSF    x5F.1
0338E:  MOVLW  04
03390:  MOVWF  FEA
03392:  MOVLW  08
03394:  MOVWF  FE9
03396:  MOVLW  04
03398:  MOVWF  01
0339A:  MOVF   x5C,W
0339C:  MOVLB  0
0339E:  RCALL  2D10
033A0:  MOVWF  FEE
033A2:  MOVLB  F
033A4:  MOVF   x5D,W
033A6:  MOVLB  0
033A8:  RCALL  2D10
033AA:  MOVWF  FEE
033AC:  DECFSZ 01,F
033AE:  BRA    33B2
033B0:  BRA    33B6
033B2:  MOVLB  F
033B4:  BRA    339A
....................    MP_RTC_SEC   = read_clock.tm_sec  ;
033B6:  MOVFF  40E,1C2
....................   
.................... 
....................    MP_RTC_YEAR  = read_clock.tm_year ;
033BA:  MOVFF  408,1BD
....................    MP_RTC_MONTH = read_clock.tm_mon  ;
033BE:  MOVFF  40B,1BE
....................    MP_RTC_DAY   = read_clock.tm_mday ;
033C2:  MOVFF  40A,1BF
....................    MP_RTC_HOUR  = read_clock.tm_hour ;
033C6:  MOVFF  40C,1C0
....................    MP_RTC_MIN   = read_clock.tm_min  ;
033CA:  MOVFF  40F,1C1
033CE:  RETURN 0
.................... }
