.................... 
.................... void MSN_FM_SECTOR_ERASE(unsigned int32 sector_address,char sector_size, unsigned int16 delay = 1000)
.................... {
....................    
....................    adsress[0]  = (unsigned int8)((sector_address>>24) & 0xFF);   // 0x __ 00 00 00
*
08FD8:  MOVLB  4
08FDA:  MOVFF  406,2D4
08FDE:  CLRF   03
....................    adsress[1]  = (unsigned int8)((sector_address>>16) & 0xFF);   // 0x 00 __ 00 00
08FE0:  MOVFF  405,2D5
08FE4:  CLRF   03
....................    adsress[2]  = (unsigned int8)((sector_address>>8)  & 0xFF);   // 0x 00 00 __ 00
08FE6:  MOVFF  404,2D6
08FEA:  CLRF   03
....................    adsress[3]  = (unsigned int8)((sector_address)     & 0xFF);   // 0x 00 00 00 __
08FEC:  MOVFF  403,2D7
08FF0:  CLRF   03
....................    
....................    MSN_FM_WRITE_ENABLE();
08FF2:  MOVLB  0
08FF4:  BRA    8FBA
....................    Output_low(Pin_A2);             //lower the CS PIN
08FF6:  BCF    F92.2
08FF8:  BCF    F89.2
....................    ///////////////////////////////////////////////////////////////////
....................    if( Sector_size == 4  ) spi_xfer(MSN_FM,0x21);                    // 4KB Sector erase
08FFA:  MOVLB  4
08FFC:  MOVF   x07,W
08FFE:  SUBLW  04
09000:  BNZ   9014
09002:  MOVLW  21
09004:  MOVWF  x1F
09006:  MOVLW  08
09008:  MOVWF  x20
0900A:  MOVLW  01
0900C:  MOVWF  x21
0900E:  MOVLB  0
09010:  RCALL  8A44
09012:  MOVLB  4
....................    if( Sector_size == 32 ) spi_xfer(MSN_FM,0x5C);                    // 32KB Sector erase
09014:  MOVF   x07,W
09016:  SUBLW  20
09018:  BNZ   902C
0901A:  MOVLW  5C
0901C:  MOVWF  x1F
0901E:  MOVLW  08
09020:  MOVWF  x20
09022:  MOVLW  01
09024:  MOVWF  x21
09026:  MOVLB  0
09028:  RCALL  8A44
0902A:  MOVLB  4
....................    if( Sector_size == 64 ) spi_xfer(MSN_FM,0xDC);                    // 64KB Sector erase
0902C:  MOVF   x07,W
0902E:  SUBLW  40
09030:  BNZ   9044
09032:  MOVLW  DC
09034:  MOVWF  x1F
09036:  MOVLW  08
09038:  MOVWF  x20
0903A:  MOVLW  01
0903C:  MOVWF  x21
0903E:  MOVLB  0
09040:  RCALL  8A44
09042:  MOVLB  4
....................    
....................    spi_xfer(MSN_FM,adsress[0]);   
09044:  MOVFF  2D4,41F
09048:  MOVLW  08
0904A:  MOVWF  x20
0904C:  MOVLW  01
0904E:  MOVWF  x21
09050:  MOVLB  0
09052:  RCALL  8A44
....................    spi_xfer(MSN_FM,adsress[1]);    
09054:  MOVFF  2D5,41F
09058:  MOVLW  08
0905A:  MOVLB  4
0905C:  MOVWF  x20
0905E:  MOVLW  01
09060:  MOVWF  x21
09062:  MOVLB  0
09064:  RCALL  8A44
....................    spi_xfer(MSN_FM,adsress[2]);    
09066:  MOVFF  2D6,41F
0906A:  MOVLW  08
0906C:  MOVLB  4
0906E:  MOVWF  x20
09070:  MOVLW  01
09072:  MOVWF  x21
09074:  MOVLB  0
09076:  RCALL  8A44
....................    spi_xfer(MSN_FM,adsress[3]);
09078:  MOVFF  2D7,41F
0907C:  MOVLW  08
0907E:  MOVLB  4
09080:  MOVWF  x20
09082:  MOVLW  01
09084:  MOVWF  x21
09086:  MOVLB  0
09088:  RCALL  8A44
....................    //////////////////////////////////////////////////////////////////
....................    Output_high(Pin_A2);           //take CS PIN higher back
0908A:  BCF    F92.2
0908C:  BSF    F89.2
....................    delay_ms(delay); 
0908E:  MOVFF  409,40A
09092:  MOVLB  4
09094:  INCF   x0A,F
09096:  DECF   x0A,F
09098:  BTFSC  FD8.2
0909A:  BRA    90A8
0909C:  SETF   x3E
0909E:  MOVLB  0
090A0:  CALL   1DA0
090A4:  MOVLB  4
090A6:  BRA    9096
090A8:  MOVFF  408,43E
090AC:  MOVLB  0
090AE:  CALL   1DA0
....................    return;
090B2:  GOTO   91F8 (RETURN)
.................... }
