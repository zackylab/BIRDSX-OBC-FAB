0419A:  SUBLW  03
0419C:  BNZ   41AA
0419E:  MOVLW  3B
041A0:  ADDWF  x35,W
041A2:  MOVWF  x36
041A4:  CLRF   x37
041A6:  CLRF   x38
041A8:  CLRF   x39
