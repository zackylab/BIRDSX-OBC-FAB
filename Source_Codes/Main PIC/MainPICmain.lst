.................... 
.................... void printtable(unsigned int8 table[], int table_size, int column_size)
.................... {
....................    for(int i = 0; i < table_size; i++) 
....................    {
....................       fprintf( PC, "%x ", table[0]);
....................       if ((i+1) %column_size  == 0 ) 
....................       {
....................          printline();
....................       }
....................    }
.................... }
