.................... // this functions will check com pic UART port incoming
.................... void CHECK_UART_INCOMING_FROM_COM_PIC()
.................... {
....................    if( CPic_available() )
*
08896:  BRA    882A
08898:  MOVF   01,F
0889A:  BZ    8900
....................    {
....................       Delay_ms(100);
0889C:  MOVLW  64
0889E:  MOVLB  4
088A0:  MOVWF  x3E
088A2:  MOVLB  0
088A4:  CALL   1DA0
....................       
....................       for( int i = 0; i<5; i++)
