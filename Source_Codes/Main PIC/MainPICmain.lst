02ACA:  MOVLW  01
02ACC:  MOVWF  x21
02ACE:  MOVLB  0
02AD0:  RCALL  2386
....................   Output_high(Pin_E2);
02AD2:  BCF    F96.2
02AD4:  BSF    F8D.2
....................   return;
02AD6:  RETURN 0
.................... }
