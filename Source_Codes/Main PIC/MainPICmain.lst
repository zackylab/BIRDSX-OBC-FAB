.................... // this functions will check com pic FAB port incoming
.................... void CHECK_UART_INCOMING_FROM_FAB_PIC()
.................... {
....................    if(FABPic_available())
*
048FE:  RCALL  4878
04900:  MOVF   01,F
04902:  BZ    496A
....................    {
....................       Delay_ms(100);
04904:  MOVLW  64
04906:  MOVLB  4
04908:  MOVWF  x3E
0490A:  MOVLB  0
0490C:  CALL   1DA0
....................       for( int i = 0; i<5; i++)
04910:  MOVLB  4
04912:  CLRF   x3C
04914:  MOVF   x3C,W
04916:  SUBLW  04
04918:  BNC   4936
....................       {
....................          if( FABPIC_Read() == 0xFA )
0491A:  MOVLB  0
0491C:  RCALL  4892
0491E:  MOVF   01,W
04920:  SUBLW  FA
04922:  BNZ   4930
....................          {
....................             FAB_TO_MPIC_ARRAY[0] = 0xFA;
04924:  MOVLW  FA
04926:  MOVLB  1
04928:  MOVWF  x10
....................             break;
0492A:  MOVLB  4
0492C:  BRA    4936
0492E:  MOVLB  0
....................          }
04930:  MOVLB  4
04932:  INCF   x3C,F
04934:  BRA    4914
....................       }
....................       
....................       for (int i=1; i<=50; i++)
04936:  MOVLW  01
04938:  MOVWF  x3D
0493A:  MOVF   x3D,W
0493C:  SUBLW  32
0493E:  BNC   496A
....................       {
....................          FAB_TO_MPIC_ARRAY[i] = FABPIC_Read();
04940:  CLRF   03
04942:  MOVF   x3D,W
04944:  ADDLW  10
04946:  MOVWF  01
04948:  MOVLW  01
0494A:  ADDWFC 03,F
0494C:  MOVFF  01,43E
04950:  MOVFF  03,43F
04954:  MOVLB  0
04956:  RCALL  4892
04958:  MOVFF  43F,FEA
0495C:  MOVFF  43E,FE9
04960:  MOVFF  01,FEF
04964:  MOVLB  4
04966:  INCF   x3D,F
04968:  BRA    493A
0496A:  MOVLB  0
....................       }
....................    }
0496C:  GOTO   4A5C (RETURN)
.................... }
