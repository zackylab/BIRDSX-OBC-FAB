.................... // this functions will print received data from Mission Boss
.................... void PRINT_RECIVED_COMMAND_FROM_MISSION_BOSS()
.................... {
....................    Fprintf(PC,"Received comand from Mission Boss >> ");
....................    for(int i = 0; i<40; i++)
