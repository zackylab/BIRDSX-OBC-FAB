01DD8:  MOVLB  F
01DDA:  BSF    x5F.5
01DDC:  MOVLB  0
01DDE:  MOVLB  4
....................       #ENDASM
....................    }
....................    
....................       if(i == 0)
01DE0:  MOVF   x45,F
01DE2:  BNZ   1DF4
....................    {
....................       #ASM
....................       movlw 0x55
01DE4:  MOVLW  55
....................       movwf EECON2
