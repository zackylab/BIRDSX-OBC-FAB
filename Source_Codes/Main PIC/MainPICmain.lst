.................... //________________________BYTE WRITE Function____________________________________________________\\
.................... void MAIN_FM_BYTE_WRITE(unsigned int32 byte_address, unsigned int8 data)
.................... {
....................    
....................    //Byte extraction
....................    adsress[0]  = (unsigned int8)((byte_address>>24) & 0xFF);   // 0x __ 00 00 00
*
02BB6:  MOVLB  4
02BB8:  MOVFF  418,2D4
02BBC:  CLRF   03
....................    adsress[1]  = (unsigned int8)((byte_address>>16) & 0xFF);   // 0x 00 __ 00 00
02BBE:  MOVFF  417,2D5
02BC2:  CLRF   03
....................    adsress[2]  = (unsigned int8)((byte_address>>8)  & 0xFF);   // 0x 00 00 __ 00
02BC4:  MOVFF  416,2D6
02BC8:  CLRF   03
....................    adsress[3]  = (unsigned int8)((byte_address)     & 0xFF);   // 0x 00 00 00 __
02BCA:  MOVFF  415,2D7
02BCE:  CLRF   03
....................  
....................    MAIN_FM_WRITE_ENABLE();
02BD0:  MOVLB  0
02BD2:  RCALL  2ABC
....................    Output_low(Pin_E2);             //lower the CS PIN
02BD4:  BCF    F96.2
02BD6:  BCF    F8D.2
....................    ///////////////////////////////////////////////////////////////////
....................    spi_xfer(MAIN_FM,0x12);         //Byte WRITE COMAND  (0x12)
02BD8:  MOVLW  12
02BDA:  MOVLB  4
02BDC:  MOVWF  x1F
02BDE:  MOVLW  08
02BE0:  MOVWF  x20
02BE2:  MOVLW  01
02BE4:  MOVWF  x21
02BE6:  MOVLB  0
02BE8:  CALL   2386
....................    spi_xfer(MAIN_FM,adsress[0]);    
02BEC:  MOVFF  2D4,41F
02BF0:  MOVLW  08
02BF2:  MOVLB  4
02BF4:  MOVWF  x20
02BF6:  MOVLW  01
02BF8:  MOVWF  x21
02BFA:  MOVLB  0
02BFC:  CALL   2386
....................    spi_xfer(MAIN_FM,adsress[1]);    
02C00:  MOVFF  2D5,41F
02C04:  MOVLW  08
02C06:  MOVLB  4
02C08:  MOVWF  x20
02C0A:  MOVLW  01
02C0C:  MOVWF  x21
02C0E:  MOVLB  0
02C10:  CALL   2386
....................    spi_xfer(MAIN_FM,adsress[2]);    
02C14:  MOVFF  2D6,41F
02C18:  MOVLW  08
02C1A:  MOVLB  4
02C1C:  MOVWF  x20
02C1E:  MOVLW  01
02C20:  MOVWF  x21
02C22:  MOVLB  0
02C24:  CALL   2386
....................    spi_xfer(MAIN_FM,adsress[3]);
02C28:  MOVFF  2D7,41F
02C2C:  MOVLW  08
02C2E:  MOVLB  4
02C30:  MOVWF  x20
02C32:  MOVLW  01
02C34:  MOVWF  x21
02C36:  MOVLB  0
02C38:  CALL   2386
.................... 
....................    spi_xfer(MAIN_FM,data); 
02C3C:  MOVFF  419,41F
02C40:  MOVLW  08
02C42:  MOVLB  4
02C44:  MOVWF  x20
02C46:  MOVLW  01
02C48:  MOVWF  x21
02C4A:  MOVLB  0
02C4C:  CALL   2386
....................    //////////////////////////////////////////////////////////////////
....................    Output_high(Pin_E2);           //take CS PIN higher back 
02C50:  BCF    F96.2
02C52:  BSF    F8D.2
....................    
....................    return;
02C54:  RETURN 0
.................... }
