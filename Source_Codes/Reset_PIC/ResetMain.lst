....................       RPIC_TO_CPIC_ARRAY[6]  = minute ;
01DAC:  MOVFF  9F,8D
....................       RPIC_TO_CPIC_ARRAY[7]  = second ;
01DB0:  MOVFF  A0,8E
....................       
....................       RPIC_TO_CPIC_ARRAY[19] = 0xC1   ;
01DB4:  MOVLW  C1
01DB6:  MOVWF  x9A
....................       for(int i = 0; i<20; i++)
01DB8:  MOVLB  1
01DBA:  CLRF   x0A
01DBC:  MOVF   x0A,W
01DBE:  SUBLW  13
01DC0:  BNC   1DE0
....................       {
....................          fputc(RPIC_TO_CPIC_ARRAY[i],CPic);
01DC2:  CLRF   03
01DC4:  MOVF   x0A,W
01DC6:  ADDLW  87
01DC8:  MOVWF  FE9
01DCA:  MOVLW  00
01DCC:  ADDWFC 03,W
01DCE:  MOVWF  FEA
01DD0:  MOVFF  FEF,10B
01DD4:  MOVF   x0B,W
01DD6:  MOVLB  0
01DD8:  RCALL  1D5C
01DDA:  MOVLB  1
01DDC:  INCF   x0A,F
01DDE:  BRA    1DBC
....................       }
....................       printline();
01DE0:  MOVLB  0
01DE2:  CALL   0C4E
