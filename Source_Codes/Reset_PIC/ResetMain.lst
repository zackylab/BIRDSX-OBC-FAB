02018:  MOVLW  01
0201A:  MOVLB  1
0201C:  MOVWF  x0E
0201E:  MOVLB  0
02020:  CALL   0654
....................    fputc(0xBB, SPic);
02024:  MOVLW  BB
02026:  RCALL  200C
....................    delay_ms(1);
02028:  MOVLW  01
0202A:  MOVLB  1
0202C:  MOVWF  x0E
0202E:  MOVLB  0
02030:  CALL   0654
....................    fputc(0xCC, SPic);
