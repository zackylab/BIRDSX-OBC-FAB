.................... void RESEPOND_TO_MPIC_90SEC_CMD()
.................... {
....................    if(MPIC_TO_RPIC_ARRAY[1] == 0x7A)
*
01634:  MOVF   22,W
01636:  SUBLW  7A
01638:  BTFSS  FD8.2
0163A:  BRA    179E
