....................       CLEAR_DATA_ARRAY( RPIC_TO_MPIC_ARRAY, 32);
01902:  MOVLB  1
01904:  CLRF   x0E
01906:  MOVLW  44
01908:  MOVWF  x0D
0190A:  MOVLW  20
0190C:  MOVWF  x0F
0190E:  MOVLB  0
01910:  RCALL  14E6
....................       RPIC_TO_MPIC_ARRAY[0]  = 0xA0   ;
01912:  MOVLW  A0
01914:  MOVWF  44
....................       RPIC_TO_MPIC_ARRAY[1]  = 0x7C   ;
01916:  MOVLW  7C
01918:  MOVWF  45
....................       RPIC_TO_MPIC_ARRAY[31] = 0xA1   ;
0191A:  MOVLW  A1
0191C:  MOVWF  x63
....................       for(int i = 0; i<32; i++)
0191E:  MOVLB  1
01920:  CLRF   x0A
01922:  MOVF   x0A,W
01924:  SUBLW  1F
01926:  BNC   1946
....................       {
....................          fputc(RPIC_TO_MPIC_ARRAY[i],MPic);
01928:  CLRF   03
0192A:  MOVF   x0A,W
0192C:  ADDLW  44
0192E:  MOVWF  FE9
01930:  MOVLW  00
01932:  ADDWFC 03,W
01934:  MOVWF  FEA
01936:  MOVFF  FEF,10B
0193A:  MOVF   x0B,W
0193C:  MOVLB  0
0193E:  RCALL  1628
01940:  MOVLB  1
01942:  INCF   x0A,F
01944:  BRA    1922
....................       }
....................       //_______________________________________________________________________
....................       
....................       if(MPIC_TO_RPIC_ARRAY[2] == 0x01) _3V3Power_Line1(BB_ON_OCP_ON)  ;
01946:  DECFSZ 23,W
01948:  BRA    1958
0194A:  MOVLW  01
0194C:  MOVWF  x0D
0194E:  MOVLB  0
01950:  CALL   06D2
01954:  BRA    1962
01956:  MOVLB  1
....................       else _3V3Power_Line1(BB_OFF_OCP_OFF)  ;
01958:  MOVLW  03
0195A:  MOVWF  x0D
0195C:  MOVLB  0
0195E:  CALL   06D2
....................       
....................       if(MPIC_TO_RPIC_ARRAY[3] == 0x01) _3V3Power_Line2(BB_ON_OCP_ON)  ;
01962:  DECFSZ 24,W
01964:  BRA    1974
01966:  MOVLW  01
01968:  MOVLB  1
0196A:  MOVWF  x0D
0196C:  MOVLB  0
0196E:  CALL   0720
01972:  BRA    1980
....................       else _3V3Power_Line2(BB_OFF_OCP_OFF)   ;
01974:  MOVLW  03
01976:  MOVLB  1
01978:  MOVWF  x0D
0197A:  MOVLB  0
0197C:  CALL   0720
....................       
....................       if(MPIC_TO_RPIC_ARRAY[4] == 0x01) _5V0Power_Line(BB_ON_OCP_ON)   ;
01980:  DECFSZ 25,W
01982:  BRA    1992
01984:  MOVLW  01
01986:  MOVLB  1
01988:  MOVWF  x0D
0198A:  MOVLB  0
0198C:  CALL   076E
01990:  BRA    199E
....................       else _5V0Power_Line(BB_OFF_OCP_OFF)  ;
01992:  MOVLW  03
01994:  MOVLB  1
01996:  MOVWF  x0D
01998:  MOVLB  0
0199A:  CALL   076E
....................       
....................       if(MPIC_TO_RPIC_ARRAY[5] == 0x01) Unreg2_Line(ON)         ;
0199E:  DECFSZ 26,W
019A0:  BRA    19B0
019A2:  MOVLW  01
019A4:  MOVLB  1
019A6:  MOVWF  x0D
019A8:  MOVLB  0
019AA:  CALL   07E6
019AE:  BRA    19BA
....................       else Unreg2_Line(OFF)  ;
