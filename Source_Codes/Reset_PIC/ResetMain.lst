.................... 
.................... /* this fucntons monitor the main pic, if no response within 10min reset pic
.................... will restart the main pic*/
.................... void MONITOR_MAIN_PIC_90SEC_COMUNICATION(int time)
.................... {
....................    if( MPIC_TIME_COUNTER >= 600 )
*
0135A:  MOVF   1C,W
0135C:  SUBLW  01
0135E:  BC    1402
01360:  XORLW  FF
01362:  BNZ   136A
01364:  MOVF   1B,W
01366:  SUBLW  57
01368:  BC    1402
....................    {
....................       MPIC_TIME_COUNTER = 0;
0136A:  CLRF   1C
0136C:  CLRF   1B
....................       NUMOF_MPIC_RST++;
0136E:  INCF   1D,F
....................       
....................       Fprintf(PC,"Hang up reset, MainPIC is turned off\n\r");
01370:  MOVLW  9E
01372:  MOVWF  FF6
01374:  MOVLW  02
01376:  MOVWF  FF7
01378:  MOVLW  00
0137A:  MOVWF  FF8
0137C:  CALL   08D0
....................       MainPic_Power(0);   // turn off main pic
01380:  MOVLB  1
01382:  CLRF   x0D
01384:  MOVLB  0
01386:  CALL   067E
....................       for( int i = 0; i<time; i++)
0138A:  MOVLB  1
0138C:  CLRF   x0B
0138E:  MOVF   x0A,W
01390:  SUBWF  x0B,W
01392:  BC    13E8
....................       {
....................          Delay_ms(1000);
01394:  MOVLW  04
01396:  MOVWF  x0C
01398:  MOVLW  FA
0139A:  MOVWF  x0E
0139C:  MOVLB  0
0139E:  CALL   0654
013A2:  MOVLB  1
013A4:  DECFSZ x0C,F
013A6:  BRA    1398
....................          Fprintf(PC,"Waiting to turn on Main Pic %02d Sec\n\r",i);
013A8:  MOVLW  C6
013AA:  MOVWF  FF6
013AC:  MOVLW  02
013AE:  MOVWF  FF7
013B0:  MOVLW  00
013B2:  MOVWF  FF8
013B4:  MOVLW  1C
013B6:  MOVWF  x0E
013B8:  MOVLB  0
013BA:  RCALL  0F12
013BC:  MOVFF  10B,10E
013C0:  MOVLW  01
013C2:  MOVLB  1
013C4:  MOVWF  x0F
013C6:  MOVLB  0
013C8:  CALL   09DA
013CC:  MOVLW  E6
013CE:  MOVWF  FF6
013D0:  MOVLW  02
013D2:  MOVWF  FF7
013D4:  MOVLW  00
013D6:  MOVWF  FF8
013D8:  MOVLW  06
013DA:  MOVLB  1
013DC:  MOVWF  x0E
013DE:  MOVLB  0
013E0:  RCALL  0F12
013E2:  MOVLB  1
013E4:  INCF   x0B,F
013E6:  BRA    138E
....................       }
....................       MainPic_Power(1);   // turn on main pic
013E8:  MOVLW  01
013EA:  MOVWF  x0D
013EC:  MOVLB  0
013EE:  CALL   067E
....................       Fprintf(PC,"MainPIC is restarted\n\r");
013F2:  MOVLW  EE
013F4:  MOVWF  FF6
013F6:  MOVLW  02
013F8:  MOVWF  FF7
013FA:  MOVLW  00
013FC:  MOVWF  FF8
013FE:  CALL   08D0
....................    }
01402:  GOTO   216E (RETURN)
.................... }
