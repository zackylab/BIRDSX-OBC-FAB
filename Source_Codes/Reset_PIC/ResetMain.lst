007C8:  BSF    xF7.2
007CA:  MOVLB  1
....................    }
....................    if( status == 0 ) 
007CC:  MOVF   x0D,F
007CE:  BNZ   07DA
....................    {
....................       output_low(PIN_D7)  ;
007D0:  BCF    F95.7
007D2:  BCF    F8C.7
....................       BIT_CLEAR(POWER_LINE_STATUS,2);
007D4:  MOVLB  0
007D6:  BCF    xF7.2
007D8:  MOVLB  1
....................    }
....................    delay_ms(50);
007DA:  MOVLW  32
007DC:  MOVWF  x0E
007DE:  MOVLB  0
007E0:  RCALL  0654
....................    RST_EXT_WDT(); 
007E2:  RCALL  0634
007E4:  RETURN 0
.................... }
.................... 
.................... void Unreg2_Line(int1 status)
.................... {
....................    if( status == 1 ) 
007E6:  MOVLB  1
007E8:  DECFSZ x0D,W
007EA:  BRA    07F6
....................    {
....................       output_high(PIN_D0) ;
007EC:  BCF    F95.0
007EE:  BSF    F8C.0
....................       BIT_SET(POWER_LINE_STATUS,1);
007F0:  MOVLB  0
007F2:  BSF    xF7.1
007F4:  MOVLB  1
....................    }
....................    if( status == 0 ) 
007F6:  MOVF   x0D,F
007F8:  BNZ   0804
....................    {
....................       output_low(PIN_D0)  ;
007FA:  BCF    F95.0
007FC:  BCF    F8C.0
....................       BIT_CLEAR(POWER_LINE_STATUS,1);
007FE:  MOVLB  0
00800:  BCF    xF7.1
00802:  MOVLB  1
....................    }
....................    delay_ms(50);
00804:  MOVLW  32
00806:  MOVWF  x0E
00808:  MOVLB  0
0080A:  RCALL  0654
....................    RST_EXT_WDT(); 
0080C:  RCALL  0634
0080E:  RETURN 0
.................... }
