0164C:  CLRF   1C
0164E:  CLRF   1B
....................       
....................       // clear RPIC_TO_MPIC array before putting new data______________________
....................       CLEAR_DATA_ARRAY( RPIC_TO_MPIC_ARRAY, 32 );
01650:  MOVLB  1
01652:  CLRF   x0E
01654:  MOVLW  44
01656:  MOVWF  x0D
01658:  MOVLW  20
0165A:  MOVWF  x0F
0165C:  MOVLB  0
0165E:  RCALL  14E6
....................       
