00CD8:  RCALL  088C
....................    fprintf(PC,"3=%d,", (POWER_LINE_STATUS>>5) & 0x01 );
00CDA:  SWAPF  xF7,W
00CDC:  MOVWF  00
00CDE:  RRCF   00,F
00CE0:  MOVLW  07
00CE2:  ANDWF  00,F
