.................... /* this fucntons monitor the com pic. if no response within 10min reset pic
.................... will restart the com pic*/
.................... void MONITOR_COM_PIC_90SEC_COMUNICATION(int time)
.................... {
....................    if( CPIC_TIME_COUNTER >= 600 )
*
01406:  MOVF   1F,W
01408:  SUBLW  01
0140A:  BC    148E
0140C:  XORLW  FF
0140E:  BNZ   1416
01410:  MOVF   1E,W
01412:  SUBLW  57
01414:  BC    148E
....................    {
....................       CPIC_TIME_COUNTER = 0;
01416:  CLRF   1F
01418:  CLRF   1E
....................       NUMOF_CPIC_RST++;
0141A:  INCF   20,F
....................       
....................       ComPic_Power(0);   // turn off main pic
0141C:  MOVLB  1
0141E:  CLRF   x0D
01420:  MOVLB  0
01422:  CALL   06A8
....................       for( int i = 0; i<time ; i++)
01426:  MOVLB  1
01428:  CLRF   x0B
0142A:  MOVF   x0A,W
0142C:  SUBWF  x0B,W
0142E:  BC    1484
....................       {
....................          Delay_ms(1000);
01430:  MOVLW  04
01432:  MOVWF  x0C
01434:  MOVLW  FA
01436:  MOVWF  x0E
01438:  MOVLB  0
0143A:  CALL   0654
0143E:  MOVLB  1
01440:  DECFSZ x0C,F
01442:  BRA    1434
....................         Fprintf(PC,"Waiting to turn on com Pic %02d Sec\n\r",i);
01444:  MOVLW  88
01446:  MOVWF  FF6
01448:  MOVLW  04
0144A:  MOVWF  FF7
0144C:  MOVLW  00
0144E:  MOVWF  FF8
01450:  MOVLW  1B
01452:  MOVWF  x0E
01454:  MOVLB  0
01456:  RCALL  0F12
01458:  MOVFF  10B,10E
0145C:  MOVLW  01
0145E:  MOVLB  1
01460:  MOVWF  x0F
01462:  MOVLB  0
01464:  CALL   09DA
01468:  MOVLW  A7
0146A:  MOVWF  FF6
0146C:  MOVLW  04
0146E:  MOVWF  FF7
01470:  MOVLW  00
01472:  MOVWF  FF8
01474:  MOVLW  06
01476:  MOVLB  1
01478:  MOVWF  x0E
0147A:  MOVLB  0
0147C:  RCALL  0F12
0147E:  MOVLB  1
01480:  INCF   x0B,F
01482:  BRA    142A
....................       }
....................       ComPic_Power(1);   // turn on main pic
01484:  MOVLW  01
01486:  MOVWF  x0D
01488:  MOVLB  0
0148A:  CALL   06A8
....................    }
0148E:  GOTO   217A (RETURN)
.................... }
