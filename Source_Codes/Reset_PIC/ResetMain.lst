.................... // here we check main pic UART is available or not if available we save in MPIC_TO_RPIC array
.................... void CHECK_UART_INCOMING_FROM_COM_PIC()
.................... {
....................    if( CPic_Available() )
*
012EA:  BRA    1296
012EC:  MOVF   01,F
012EE:  BZ    1354
....................    {
....................       Delay_ms(100);
012F0:  MOVLW  64
012F2:  MOVLB  1
012F4:  MOVWF  x0E
012F6:  MOVLB  0
012F8:  CALL   0654
....................       for( int i = 0; i<10; i++ )
012FC:  MOVLB  1
012FE:  CLRF   x0A
01300:  MOVF   x0A,W
01302:  SUBLW  09
01304:  BNC   1320
....................       {
....................          if( CPic_Read() == 0xC0 )
01306:  MOVLB  0
01308:  RCALL  129E
0130A:  MOVF   01,W
0130C:  SUBLW  C0
0130E:  BNZ   131A
....................          {
....................             CPIC_TO_RPIC_ARRAY[0] = 0xC0 ;
01310:  MOVLW  C0
01312:  MOVWF  x64
....................             break;
01314:  MOVLB  1
01316:  BRA    1320
01318:  MOVLB  0
....................          }
0131A:  MOVLB  1
0131C:  INCF   x0A,F
0131E:  BRA    1300
....................       }
.................... 
....................       for(int i = 1; i<=30; i++)
01320:  MOVLW  01
01322:  MOVWF  x0B
01324:  MOVF   x0B,W
01326:  SUBLW  1E
01328:  BNC   1354
....................       {
....................          CPIC_TO_RPIC_ARRAY[i] = CPic_Read();
0132A:  CLRF   03
0132C:  MOVF   x0B,W
0132E:  ADDLW  64
01330:  MOVWF  01
01332:  MOVLW  00
01334:  ADDWFC 03,F
01336:  MOVFF  01,10C
0133A:  MOVFF  03,10D
0133E:  MOVLB  0
01340:  RCALL  129E
01342:  MOVFF  10D,FEA
01346:  MOVFF  10C,FE9
0134A:  MOVFF  01,FEF
0134E:  MOVLB  1
01350:  INCF   x0B,F
01352:  BRA    1324
01354:  MOVLB  0
....................       }
....................    }
01356:  GOTO   2162 (RETURN)
.................... }
