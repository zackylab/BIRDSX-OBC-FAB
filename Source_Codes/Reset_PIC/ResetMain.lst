017BC:  CLRF   x0E
017BE:  MOVLW  44
017C0:  MOVWF  x0D
017C2:  MOVLW  20
017C4:  MOVWF  x0F
017C6:  MOVLB  0
017C8:  RCALL  14E6
....................       RPIC_TO_MPIC_ARRAY[0]  = 0xA0   ;
017CA:  MOVLW  A0
017CC:  MOVWF  44
....................       RPIC_TO_MPIC_ARRAY[1]  = 0x7B   ;
017CE:  MOVLW  7B
017D0:  MOVWF  45
....................       RPIC_TO_MPIC_ARRAY[31] = 0xA1   ;
017D2:  MOVLW  A1
017D4:  MOVWF  x63
....................       for(int i = 0; i<32; i++)
017D6:  MOVLB  1
017D8:  CLRF   x0A
017DA:  MOVF   x0A,W
017DC:  SUBLW  1F
017DE:  BNC   17FE
....................       {
....................          fputc(RPIC_TO_MPIC_ARRAY[i],MPic);
017E0:  CLRF   03
017E2:  MOVF   x0A,W
017E4:  ADDLW  44
017E6:  MOVWF  FE9
017E8:  MOVLW  00
017EA:  ADDWFC 03,W
017EC:  MOVWF  FEA
017EE:  MOVFF  FEF,10B
017F2:  MOVF   x0B,W
017F4:  MOVLB  0
017F6:  RCALL  1628
017F8:  MOVLB  1
017FA:  INCF   x0A,F
017FC:  BRA    17DA
....................       }
....................       //_______________________________________________________________________
....................       
....................       //Updating the RTC
....................       year   = MPIC_TO_RPIC_ARRAY[2]  ;
017FE:  MOVFF  23,9B
....................       month  = MPIC_TO_RPIC_ARRAY[3]  ;
01802:  MOVFF  24,9C
....................       day    = MPIC_TO_RPIC_ARRAY[4]  ;
01806:  MOVFF  25,9D
....................       hour   = MPIC_TO_RPIC_ARRAY[5]  ;
0180A:  MOVFF  26,9E
