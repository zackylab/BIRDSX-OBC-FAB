00CF4:  MOVLW  3D
00CF6:  MOVLB  1
00CF8:  MOVWF  x14
00CFA:  MOVLB  0
00CFC:  RCALL  088C
00CFE:  MOVFF  10A,10B
00D02:  MOVLW  18
00D04:  MOVLB  1
00D06:  MOVWF  x0C
