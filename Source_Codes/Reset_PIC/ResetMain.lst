01240:  MOVWF  01
01242:  MOVLW  00
01244:  ADDWFC 03,F
01246:  MOVFF  01,10C
0124A:  MOVFF  03,10D
0124E:  MOVLB  0
01250:  CALL   0832
01254:  MOVFF  10D,FEA
01258:  MOVFF  10C,FE9
0125C:  MOVFF  01,FEF
....................          fprintf(PC, "%X ", MPIC_TO_RPIC_ARRAY[i]);
01260:  CLRF   03
01262:  MOVLB  1
01264:  MOVF   x0B,W
01266:  ADDLW  21
01268:  MOVWF  FE9
0126A:  MOVLW  00
0126C:  ADDWFC 03,W
0126E:  MOVWF  FEA
01270:  MOVFF  FEF,10D
01274:  MOVLW  37
01276:  MOVWF  x0E
01278:  MOVLB  0
