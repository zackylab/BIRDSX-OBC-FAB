....................       CLEAR_DATA_ARRAY( RPIC_TO_CPIC_ARRAY, 20);
01D82:  MOVLB  1
01D84:  CLRF   x0E
01D86:  MOVLW  87
01D88:  MOVWF  x0D
01D8A:  MOVLW  14
01D8C:  MOVWF  x0F
