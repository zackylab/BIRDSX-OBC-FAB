.................... 
.................... ///////////////////////////////////////////////////////////////////////////////
.................... /////////////////////////// ADC Related Function //////////////////////////////
.................... ///////////////////////////////////////////////////////////////////////////////
.................... 
.................... // C3 = Raw power monitor enable
.................... // A2 (AN2) = Raw voltage measure
.................... // A1 (AN1) = 3V3-1 current measure
.................... // A0 (AN0) = 3V3-2 current measure
.................... // A5 (AN4) = 5V0 current measure
.................... // A4 (AN6) = UNREG-1 current measure
.................... // C2 (AN9) = UNREG-2 current measure
.................... 
.................... unsigned int16 _Raw_power_ADC_val       = 0 ;          
.................... unsigned int16 _3V3_1_current_ADC_val   = 0 ;          
.................... unsigned int16 _3V3_2_current_ADC_val   = 0 ;          
.................... unsigned int16 _5V0_current_ADC_val     = 0 ;          
.................... unsigned int16 _UNREG_1_current_ADC_val = 0 ;      
.................... unsigned int16 _UNREG_2_current_ADC_val = 0 ;    
.................... 
.................... 
.................... // below functions are current measuring functions_____________________________
.................... unsigned int16 Measure_Raw_voltage() // A2 (AN2) = Raw voltage measure
.................... {
....................    Output_low(PIN_C3);
*
01506:  BCF    F94.3
01508:  BCF    F8B.3
....................    Delay_us(100);
0150A:  MOVLW  85
0150C:  MOVWF  00
0150E:  DECFSZ 00,F
01510:  BRA    150E
....................    
....................    SET_ADC_CHANNEL(2); 
01512:  MOVLW  02
01514:  MOVLB  E
01516:  MOVWF  x86
....................    delay_us(20);
01518:  MOVLW  1A
0151A:  MOVWF  00
0151C:  DECFSZ 00,F
0151E:  BRA    151C
01520:  NOP   
....................    Output_high(PIN_C3);
01522:  BCF    F94.3
01524:  BSF    F8B.3
....................    return READ_ADC(); 
01526:  BCF    FC0.0
01528:  BSF    FC0.1
0152A:  BTFSS  FC0.0
0152C:  BRA    152A
0152E:  MOVFF  FC3,02
01532:  MOVFF  FC2,01
01536:  MOVFF  FC3,03
0153A:  MOVFF  FC3,02
0153E:  MOVLB  0
01540:  GOTO   1662 (RETURN)
.................... }
.................... 
.................... unsigned int16 Measure_3V3_1_current() // A1 (AN1) = 3V3-1 current measure
.................... {
....................    SET_ADC_CHANNEL(1); 
01544:  MOVLW  01
01546:  MOVLB  E
01548:  MOVWF  x86
....................    delay_us(20);
0154A:  MOVLW  1A
0154C:  MOVWF  00
0154E:  DECFSZ 00,F
01550:  BRA    154E
01552:  NOP   
....................    return READ_ADC(); 
01554:  BCF    FC0.0
01556:  BSF    FC0.1
01558:  BTFSS  FC0.0
0155A:  BRA    1558
0155C:  MOVFF  FC3,02
01560:  MOVFF  FC2,01
01564:  MOVFF  FC3,03
01568:  MOVFF  FC3,02
0156C:  MOVLB  0
0156E:  GOTO   166C (RETURN)
.................... }
.................... 
.................... unsigned int16 Measure_3V3_2_current() // A0 (AN0) = 3V3-2 current measure
.................... {
....................    SET_ADC_CHANNEL(0); 
01572:  MOVLB  E
01574:  CLRF   x86
....................    delay_us(20);
01576:  MOVLW  1A
01578:  MOVWF  00
0157A:  DECFSZ 00,F
0157C:  BRA    157A
0157E:  NOP   
....................    return READ_ADC(); 
01580:  BCF    FC0.0
01582:  BSF    FC0.1
01584:  BTFSS  FC0.0
01586:  BRA    1584
01588:  MOVFF  FC3,02
0158C:  MOVFF  FC2,01
01590:  MOVFF  FC3,03
01594:  MOVFF  FC3,02
01598:  MOVLB  0
0159A:  GOTO   1676 (RETURN)
.................... }
.................... 
.................... unsigned int16 Measure_5V0_current()  // A5 (AN4) = 5V0 current measure
