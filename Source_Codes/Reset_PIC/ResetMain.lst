.................... #include <ADC_Power_Lines_Control.c>
.................... #define ON  1
.................... #define OFF 0
.................... 
.................... #define BB_ON_OCP_ON   1
.................... #define BB_ON_OCP_OFF  2
.................... #define BB_OFF_OCP_OFF 3
.................... // this variable will have the power line status as an example
.................... // bit 7 of the variable will say whether main pic is on or off 1 = on, 0 = off
.................... unsigned int8 POWER_LINE_STATUS = 0;
.................... unsigned int8 RESET_TIME = 0;
.................... 
.................... // this will handle the Main pic compic buck boost converter___________________
.................... void MP_CP_BuckBoost(int1 status)
.................... {
....................    if( status == ON ) 
*
0063A:  MOVLB  1
0063C:  DECFSZ x0A,W
0063E:  BRA    0644
....................    { 
....................       output_LOW(PIN_C4); 
00640:  BCF    F94.4
00642:  BCF    F8B.4
....................    }
....................    
....................    if( status == OFF ) 
00644:  MOVF   x0A,F
00646:  BNZ   064C
....................    {
....................       output_HIGH(PIN_C4) ;
00648:  BCF    F94.4
0064A:  BSF    F8B.4
....................    }
....................    RST_EXT_WDT(); 
0064C:  MOVLB  0
0064E:  RCALL  0634
00650:  GOTO   0902 (RETURN)
.................... }
.................... 
.................... // this will handle main pic power_____________________________________________
.................... void MainPic_Power(int1 status)
.................... {
....................    if( status == 1 )
*
0067E:  MOVLB  1
00680:  DECFSZ x0D,W
00682:  BRA    068E
....................    {
....................       output_high(PIN_F5);
00684:  BCF    F97.5
00686:  BSF    F8E.5
....................       BIT_SET(POWER_LINE_STATUS,7); 
00688:  MOVLB  0
0068A:  BSF    xF7.7
0068C:  MOVLB  1
....................    }
....................    if( status == 0 )
0068E:  MOVF   x0D,F
00690:  BNZ   069C
....................    {
....................       output_low(PIN_F5) ;
00692:  BCF    F97.5
00694:  BCF    F8E.5
....................       BIT_CLEAR(POWER_LINE_STATUS,7);
00696:  MOVLB  0
00698:  BCF    xF7.7
0069A:  MOVLB  1
....................    }
....................    delay_ms(50);
0069C:  MOVLW  32
0069E:  MOVWF  x0E
006A0:  MOVLB  0
006A2:  RCALL  0654
....................    RST_EXT_WDT(); 
006A4:  RCALL  0634
006A6:  RETURN 0
.................... }
