....................       _Raw_power_ADC_val       = Measure_Raw_voltage() ;          
01660:  BRA    1506
01662:  MOVFF  02,FC
01666:  MOVFF  01,FB
....................       _3V3_1_current_ADC_val   = Measure_3V3_1_current() ;          
0166A:  BRA    1544
0166C:  MOVFF  02,FE
01670:  MOVFF  01,FD
....................       _3V3_2_current_ADC_val   = Measure_3V3_2_current() ;
01674:  BRA    1572
01676:  MOVFF  02,100
0167A:  MOVFF  01,FF
....................       _5V0_current_ADC_val     = Measure_5V0_current() ;          
0167E:  BRA    159E
01680:  MOVFF  02,102
01684:  MOVFF  01,101
....................       _UNREG_1_current_ADC_val = Measure_UNREG_1_current() ;      
01688:  BRA    15CC
0168A:  MOVFF  02,104
0168E:  MOVFF  01,103
....................       _UNREG_2_current_ADC_val = Measure_UNREG_2_current() ; 
01692:  BRA    15FA
01694:  MOVFF  02,106
01698:  MOVFF  01,105
....................       
....................       RPIC_TO_MPIC_ARRAY[0]    = 0xA0   ;     // header
0169C:  MOVLW  A0
